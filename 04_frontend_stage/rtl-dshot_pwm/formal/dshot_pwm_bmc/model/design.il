  connect \crc4_calc$func$dshot_pwm.v:350$16.data 12'x
  connect \crc4_calc$func$dshot_pwm.v:292$12.i 32'x
  connect \crc4_calc$func$dshot_pwm.v:292$12.crc 4'x
  connect \crc4_calc$func$dshot_pwm.v:292$12.data 12'x
  connect \i 2
  connect \wb_offset \wb_adr_i [5:0]
end
